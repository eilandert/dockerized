
# roundcube.rules — Snuffleupagus rulebook for the Roundcube webmail
# application (https://roundcube.net/).
#
# Roundcube specifics:
#   - Uses its own session handler (db / memcache / redis) and the
#     `roundcube_sessauth` cookie, NOT PHPSESSID for auth. We still
#     encrypt PHPSESSID — RC plugins occasionally use it.
#   - Talks to backend IMAP / SMTP / Sieve / managesieve via socket;
#     does NOT shell out, so exec/system/proc_open are banned outright.
#   - Heavy on mb_* and iconv for MIME decoding — those are allowed
#     (Snuffleupagus doesn't restrict them).
#   - Uses imap_*, mail() for envelope-from rewriting, and gettext for
#     i18n. Mail header injection rules still apply.
#   - Plugin folder includes Net_LDAP2, Crypt_GPG (calls gpg binary
#     when enable_enigma=true) — if you enable enigma, move that
#     installation to wordpress-lax.rules-equivalent settings (or
#     write a roundcube-with-enigma.rules variant).
#   - Default plugin set (archive, zipdownload, password) writes
#     temp files into config_dir/temp; no .php writes.
#
# Strictness audit (RC 1.6.16 source scan, 2026-06-03):
#   - rcmail_output_html.php DOES call eval("return ($expr);") for its
#     template conditionals. eval() therefore MUST NOT be disabled. The
#     eval_blacklist below only forbids decode/exec tokens *inside* the
#     eval'd string; RC's template expressions never contain those.
#   - rcube_image.php shells out via rcube::exec()->shell_exec() ONLY when
#     im_convert_path/im_identify_path are configured. We ship php-gd and
#     leave those null, so no subprocess runs — exec/shell_exec are banned.
#   - proc_open is only reached by crypt_gpg (enigma, NOT shipped) and the
#     ldap_ppolicy/dbmail/virtualmin password drivers (NOT used; driver=sql).
#     => proc_open banned outright.
#   - rcube_imap_generic.php calls putenv('KRB5CCNAME=...') for GSSAPI IMAP
#     auth; KRB5CCNAME is deliberately NOT in the putenv blacklist below.
#   - .php writes only occur in the unused dovecot_passwdfile driver, so the
#     file_put_contents/.php guard is safe.

# ==== Mandatory init ====
# secret_key is injected PER DEPLOYMENT at boot by the s6 init-bootstrap oneshot:
# it writes a copy of this rulebook onto the writable config volume with the line below replaced by
# a unique key (Docker secret > env ROUNDCUBEMAIL_SP_SECRET > persisted
# <config>/.sp_secret > generated), and points sp.configuration_file at that copy.
# This baked value is a build-time placeholder and is NOT what runs — do not rely
# on it. (The rootfs is read-only, so this file cannot be rewritten in place.)
sp.global.secret_key("__SP_SECRET_KEY_REPLACED_AT_BOOT__");
sp.harden_random.enable();

@condition extension_loaded("xml");
sp.xxe_protection.enable();
@end_condition;

# ==== Baseline (php-relax core, duplicated due to HEAD include behaviour) ====

sp.wrappers_whitelist.list("file,php,phar");

# RFI / path traversal
sp.disable_function.function("require").param("file").regexp("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg)://").drop();
sp.disable_function.function("include").param("file").regexp("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg)://").drop();
sp.disable_function.function("require_once").param("file").regexp("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg)://").drop();
sp.disable_function.function("include_once").param("file").regexp("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg)://").drop();
sp.disable_function.function_r("^(require|include)(_once)?$").value_r("^php://(stdin|stdout|stderr|input|output|memory|temp)").drop();
sp.disable_function.function_r("^(require|include)(_once)?$").value_r("\\.\\./+\\.\\./+\\.\\./+").drop();

# Eval / decode chains
sp.eval_blacklist.list("base64_decode", "str_rot13", "gzuncompress", "gzinflate");
sp.disable_function.function("assert").param("assertion").value_type("string").drop();
sp.disable_function.function("create_function").drop();
sp.disable_function.function("system>base64_decode").drop();
sp.disable_function.function("shell_exec>base64_decode").drop();
sp.disable_function.function("exec>base64_decode").drop();
sp.disable_function.function("passthru>base64_decode").drop();
sp.disable_function.function("proc_open>base64_decode").drop();

# Mail header injection — extra important for a webmail app
sp.disable_function.function("mail").param("to").value_r("\\n").drop();
sp.disable_function.function("mail").param("subject").value_r("\\n").drop();
sp.disable_function.function("mail").param("additional_params").value_r("\\-").drop();
sp.disable_function.function("mail").param("additional_headers").key_r("^(to|b?cc)$").drop();

# Environment hijacking
sp.disable_function.function("putenv").param("assignment").value_r("^LD_").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^GCONV_").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^PATH=").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^IFS=").drop();

# World-writable chmod
sp.disable_function.function("chmod").param("permissions").value("438").drop();
sp.disable_function.function("chmod").param("permissions").value("511").drop();

# Uploaded file rename guard (RC's attachment uploads land in temp/
# with random names; .ph/.ht targets would be an attack)
sp.disable_function.function("move_uploaded_file").param("to").value_r("\\.ph").drop();
sp.disable_function.function("move_uploaded_file").param("to").value_r("\\.ht").drop();

# cURL SSL + SSRF
sp.disable_function.function("curl_setopt").param("option").value("64").drop().alias("CURLOPT_SSL_VERIFYCLIENT off blocked");
sp.disable_function.function("curl_setopt").param("option").value("81").drop().alias("CURLOPT_SSL_VERIFYHOST off blocked");
sp.disable_function.function("curl_setopt").param("value").value_r("file://").drop().alias("file:// in curl blocked");
sp.disable_function.function("curl_init").param("url").value_r("file://").drop().alias("file:// in curl blocked");

# ==== Roundcube-specific additions ====

# Secure cookies on HTTPS. RC's own auth cookie already sets it via
# session.cookie_secure=on, this catches plugin-set cookies.
sp.auto_cookie_secure.enable();

# Encrypt PHPSESSID. RC's main session is on roundcube_sessauth, but
# plugins sometimes touch $_SESSION; encrypting PHPSESSID is defense
# in depth.
sp.cookie_encryption.name("PHPSESSID").encrypt();

# ---- Outright bans on subprocess execution ----
# Vanilla Roundcube has zero subprocess calls. Only the enigma plugin
# (PGP) calls gpg via proc_open — if enigma is enabled, override this
# block in a roundcube-enigma.rules variant.
sp.disable_function.function("exec").drop();
sp.disable_function.function("system").drop();
sp.disable_function.function("shell_exec").drop();
sp.disable_function.function("passthru").drop();
sp.disable_function.function("proc_open").drop();
sp.disable_function.function("popen").drop();
sp.disable_function.function("fpassthru").drop();
sp.disable_function.function("pcntl_exec").drop();
sp.disable_function.function("pcntl_fork").drop();
sp.disable_function.function("dl").drop();

# ---- Reconnaissance ----
sp.disable_function.function("phpinfo").drop();
sp.disable_function.function("php_uname").drop();
sp.disable_function.function("show_source").drop();
sp.disable_function.function("highlight_file").drop();

# ---- POSIX privilege-mutation ----
sp.disable_function.function("posix_kill").drop();
sp.disable_function.function("posix_setegid").drop();
sp.disable_function.function("posix_seteuid").drop();
sp.disable_function.function("posix_setgid").drop();
sp.disable_function.function("posix_setpgid").drop();
sp.disable_function.function("posix_setsid").drop();
sp.disable_function.function("posix_setuid").drop();

# ---- Writing PHP-loadable files ----
sp.disable_function.function("file_put_contents").param("filename").regexp(".*\\.(ph(p[3-9]?|tml|ar)|inc)$").drop();
sp.disable_function.function("fopen").param("filename").regexp(".*\\.(ph(p[3-9]?|tml|ar)|inc)$").pos(0).drop();
sp.disable_function.function("fwrite").param("data").regexp("(?i)<\\?(php|=|\\s)").drop();

# ---- ini_set on security-critical keys ----
sp.disable_function.function("ini_set").param("option").value("assert.active").drop();
sp.disable_function.function("ini_set").param("option").value("zend.assertions").drop();
sp.disable_function.function("ini_set").param("option").value("include_path").drop();
sp.disable_function.function("ini_set").param("option").value("open_basedir").drop();
sp.disable_function.function("ini_set").param("option").value("disable_functions").drop();
sp.disable_function.function("ini_set").param("option").value("allow_url_include").drop();
sp.disable_function.function("ini_set").param("option").value("allow_url_fopen").drop();

# ==== STRICT additions (2026-06-03 source audit) ====
# This block hardens beyond the baseline above. Everything here was verified
# against the RC 1.6.16 source tree to NOT break the default feature set
# (GD imaging, sql password driver, managesieve over socket, twofactor_gauthenticator).

# ---- Block the remaining subprocess + privilege primitives ----
# proc_close/proc_get_status/proc_terminate/proc_nice are only meaningful
# alongside proc_open (already banned); ban them so a partial bypass is useless.
sp.disable_function.function("proc_close").drop();
sp.disable_function.function("proc_get_status").drop();
sp.disable_function.function("proc_nice").drop();
sp.disable_function.function("proc_terminate").drop();
sp.disable_function.function("pcntl_setpriority").drop();
sp.disable_function.function("posix_setrlimit").drop();

# ---- Reconnaissance / info-leak (extends the baseline four) ----
sp.disable_function.function("posix_getpwuid").drop();
sp.disable_function.function("posix_getgrgid").drop();
sp.disable_function.function("posix_uname").drop();
sp.disable_function.function("phpcredits").drop();
sp.disable_function.function("getmyuid").drop();
sp.disable_function.function("getmygid").drop();

# ---- Loadable-code / runtime-module injection ----
# (dl() is already dropped in the baseline block above.)
sp.disable_function.function("ini_alter").drop();

# ---- Writing PHP-loadable files: also cover the *_once / stream wrappers
#      and php:// targets, plus base64-piped writes. ----
sp.disable_function.function("file_put_contents").param("data").value_r("(?i)<\\?(php|=|\\s)").drop();
sp.disable_function.function("fputs").param("data").value_r("(?i)<\\?(php|=|\\s)").drop();
sp.disable_function.function("file_put_contents").param("filename").regexp("^php://").drop();

# ---- Symlink / hardlink games (used to read outside open_basedir) ----
sp.disable_function.function("symlink").param("link").value_r("\\.\\./").drop();
sp.disable_function.function("link").param("link").value_r("\\.\\./").drop();

# ---- mb_ereg_replace /e and preg_replace /e style eval-on-match ----
# preg_replace /e was removed in PHP 7 but mb_ereg_replace 'e' still evals.
sp.disable_function.function("mb_ereg_replace").param("option").value_r("e").drop();
sp.disable_function.function("mb_eregi_replace").param("option").value_r("e").drop();

# ---- Extra putenv hijack vectors (KRB5CCNAME deliberately NOT listed —
#      RC needs it for GSSAPI IMAP auth) ----
sp.disable_function.function("putenv").param("assignment").value_r("^LD_PRELOAD").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^LD_LIBRARY_PATH").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^NLSPATH").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^ENV=").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^BASH_ENV").drop();

# ---- SSRF / scheme abuse via fopen + file_get_contents ----
sp.disable_function.function("file_get_contents").param("filename").value_r("^(phar|expect|ssh2|ogg|rar)://").drop();
sp.disable_function.function("fopen").param("filename").value_r("^(phar|expect|ssh2|ogg|rar)://").drop();
sp.disable_function.function("readfile").param("filename").value_r("^(phar|expect|ssh2)://").drop();

# ---- Deserialisation gadget surface (RC stores serialized prefs in DB; it
#      uses its own (un)serialize, not these) ----
sp.disable_function.function("unserialize").param("data").value_r("O:\\+?\\d+:\"(SplFileObject|SplTempFileObject|GuzzleHttp)").drop();
