# syntax=docker/dockerfile:1.7
# This file might be outdated, see https://github.com/eilandert/dockerized for a recent one
FROM    eilandert/ubuntu-base:rolling
LABEL org.opencontainers.image.authors="eilandert"
LABEL org.opencontainers.image.source="https://github.com/eilandert/dockerized"

LABEL   maintainer="Thijs Eilander <eilander@myguard.nl>"
ENV     DEBIAN_FRONTEND="noninteractive"
COPY --chmod=0755 bootstrap.sh /bootstrap.sh
COPY main.cf /tmp/main.cf
RUN set -ex ;\
    apt-get update ;\
    apt-get -y --no-install-recommends install \
      ca-certificates tzdata openssl syslog-ng \
      postfix-cdb \
      postfix-ldap \
      postfix-lmdb \
      postfix-mysql \
      postfix-pcre \
      postfix-pgsql \
      postfix-sqlite \
      postfix \
      mimalloc \
      libjemalloc2 \
      ;\
    apt-get -y autoremove && apt-get -y autoclean && rm -rf /var/lib/apt/lists/* ;\
    # Replace the apt-postinst main.cf with the myguard hardened overlay
    # (TLSv1.2+ floor, PFS-only ciphers, hybrid PQ KEM, anti-spoof smtpd
    # restrictions) before stashing /etc/postfix as the first-run seed.
    mv /tmp/main.cf /etc/postfix/main.cf ;\
    mv /etc/postfix /etc/postfix.orig ;\
    chmod +x /bootstrap.sh
VOLUME [ "/var/lib/postfix" ]
EXPOSE 25 587
COPY syslog-ng.conf /etc/syslog-ng

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 CMD postfix status > /dev/null 2>&1 && pgrep -x master > /dev/null || exit 1

CMD [ "/bootstrap.sh" ]



