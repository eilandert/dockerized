# syntax=docker/dockerfile:1.7
# This file might be outdated, see https://github.com/eilandert/dockerized for a recent one
FROM eilandert/ubuntu-base:rolling
LABEL   org.opencontainers.image.authors="eilandert" \
        org.opencontainers.image.source="https://github.com/eilandert/dockerized" \
        maintainer="Thijs Eilander <eilander@myguard.nl>"
ENV     DEBIAN_FRONTEND="noninteractive" \
        LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libmimalloc-secure.so
COPY --chmod=0755 bootstrap.sh /bootstrap.sh
COPY    syslog-ng.conf /etc/syslog-ng

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    set -ex ;\
    rm -f /etc/apt/apt.conf.d/docker-clean ;\
    # Base image registers a 0000 root:adm statoverride for sudo; we want
    # a working sudo here so undo the override BEFORE the install so dpkg
    # places the binary with its normal setuid mode.
    dpkg-statoverride --remove /usr/bin/sudo 2>/dev/null || true ;\
    dpkg-statoverride --remove /bin/sudo     2>/dev/null || true ;\
    apt-get update ;\
    apt-get -y --no-install-recommends install \
      ca-certificates tzdata openssl syslog-ng \
      openssh-server \
      openssh-client \
      openssh-sftp-server \
      libpam-google-authenticator \
      rsync \
      sudo \
      libjemalloc2 \
      mimalloc \
      ;\
    apt-get -y autoremove ;\
    mv /etc/ssh /etc/ssh.orig ;\
    mkdir -p /run/sshd ;\
    rm -f /etc/motd
VOLUME /home
VOLUME /etc/ssh
EXPOSE 22

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 CMD pgrep -x sshd > /dev/null && ss -lnt | grep -q ":22 " || exit 1

CMD ["/bootstrap.sh"]
