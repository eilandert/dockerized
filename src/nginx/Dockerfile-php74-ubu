FROM    eilandert/php-fpm:7.4
LABEL   maintainer="Thijs Eilander <eilander@myguard.nl>" \
        org.opencontainers.image.title="Nginx with ModSecurity & PageSpeed" \
        org.opencontainers.image.description="High-performance web server with security and optimization modules" \
        org.opencontainers.image.url="https://github.com/eilandert/dockerized" \
        org.opencontainers.image.source="https://github.com/eilandert/dockerized/tree/master/nginx" \
        org.opencontainers.image.vendor="MyGuard" \
        org.opencontainers.image.version="#VERSION#"
ENV     DEBIAN_FRONTEND="noninteractive"

COPY    bootstrap.sh /bootstrap.sh

RUN set -ex ;\
    echo "deb [trusted=yes] http://deb.myguard.nl:8888 ${DIST} main" > /etc/apt/sources.list.d/deb.myguard.nl.list ;\
    if [ -d /etc/php.orig ]; then cp -rn /etc/php.orig/* /etc/php/ 2>/dev/null || true; fi ;\
    apt-get update ;\
    apt-get -y upgrade

RUN apt-get -y --no-install-recommends install \
      brotli \
      curl \
      fcgiwrap \
      geoip-bin \
      libjemalloc2 \
      libluajit-5.1-2 \
      lua-http \
      lua-socket \
      lua-zlib \
      lua-resty \
      mimalloc \
      modsecurity-crs \
      nginx-full \
      openssl \
      ssl-cert \
      zstd ;\
    apt-get -y autoremove && apt-get -y autoclean ;\
    rm -rf /var/lib/apt/lists/

RUN mv /etc/nginx /etc/nginx.orig ;\
    mv /etc/modsecurity /etc/modsecurity.orig ;\
    mkdir -p /etc/nginx ;\
    mkdir -p /etc/modsecurity ;\
    chmod +x /bootstrap.sh ;\
    rm -f /var/spool/nullmailer/trigger
WORKDIR /etc/nginx
EXPOSE  443/udp
EXPOSE  443 443
EXPOSE  80 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD curl -f http://localhost/ || exit 1

CMD     ["/bootstrap.sh"]

