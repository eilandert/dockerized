# syntax=docker/dockerfile:1.7
# vim:set ft=dockerfile:
FROM eilandert/debian-base:stable

LABEL org.opencontainers.image.authors="eilandert" \
      org.opencontainers.image.source="https://github.com/eilandert/dockerized" \
      org.opencontainers.image.url="https://hub.docker.com/r/eilandert/mariadb" \
      org.opencontainers.image.documentation="https://deb.myguard.nl" \
      org.opencontainers.image.base.name="docker.io/eilandert/debian-base:stable" \
      org.opencontainers.image.title="MariaDB (myguard build, Debian)" \
      org.opencontainers.image.description="Daily-rebuilt MariaDB LTS from https://deb.myguard.nl — auto-tracks the latest LTS series via the MariaDB Foundation API (no version pin). SSD-tuned defaults (60-myguard.cnf), jemalloc linked in, -march=x86-64-v2, Galera/wsrep stripped, no test/dbgsym bloat, ships mariadb-myguard-tuner. setuid/setgid bits stripped." \
      org.opencontainers.image.version="lts" \
      org.opencontainers.image.vendor="myguard" \
      org.opencontainers.image.licenses="GPL-2.0" \
      maintainer="Thijs Eilander <eilander@myguard.nl>"

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8

# Pin mysql/mariadb UID/GID so bind-mounted /var/lib/mysql volumes from an
# earlier image generation still own correctly. Create *before* the package
# install so debhelper's postinst doesn't pick a random UID.
RUN groupadd -r -g 999 mysql && \
    useradd  -r -u 999 -g mysql --home-dir /var/lib/mysql --shell /usr/sbin/nologin mysql

# BuildKit cache mounts: apt lists+archives live on cache mounts (not in
# image layers). The base image already wires /etc/apt/sources.list.d/
# deb.myguard.nl.list with the proper signed-by= key, so we don't add it
# here — packages flow from https://deb.myguard.nl automatically.
#
# Versions are deliberately *not* pinned: this image always picks up the
# latest LTS rebuild that the deb/mariadb/ build.sh has pushed. CI/cron
# rebuilds keep us current.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    set -eux ;\
    rm -f /etc/apt/apt.conf.d/docker-clean ;\
    apt-get update ;\
    apt-get -y -o Dpkg::Options::=--force-confnew \
               -o Dpkg::Options::=--force-confmiss upgrade ;\
    # postinst creates /var/lib/mysql; pre-fake it so we control ownership
    mkdir -p /var/lib/mysql/mysql && touch /var/lib/mysql/mysql/user.frm ;\
    # Pre-seed debconf so postinst stays quiet (root password is set by
    # docker-entrypoint.sh later via MARIADB_ROOT_PASSWORD).
    echo "mariadb-server mysql-server/root_password password unused"       | debconf-set-selections ;\
    echo "mariadb-server mysql-server/root_password_again password unused" | debconf-set-selections ;\
    apt-get -y --no-install-recommends install \
        mariadb-server \
        mariadb-backup \
        mariadb-myguard-tuner \
        ca-certificates \
        pwgen \
        tzdata \
        zstd \
    ;\
    # ---- Trim ---------------------------------------------------------- \
    # Container has no apparmor enforcement and no systemd, so drop the
    # profile + systemd units (still installed by the deb but useless).
    rm -rf /etc/apparmor.d/mariadbd \
           /usr/share/apport \
           /lib/systemd/system/mariadb-extra.socket \
           /lib/systemd/system/mariadb-extra@.socket \
    ;\
    # The Debian postinst's first-boot mysql_install_db is replaced by
    # docker-entrypoint.sh's MARIADB_* env logic. Remove the half-init.
    rm -rf /var/lib/mysql ;\
    # ---- Layout -------------------------------------------------------- \
    mkdir -p /var/lib/mysql /run/mysqld /docker-entrypoint-initdb.d ;\
    chown -R mysql:mysql /var/lib/mysql /run/mysqld ;\
    # /run/mysqld 1777 so the entrypoint's setpriv-to-mysql can still write
    # the socket regardless of the UID the user overrides to.
    chmod 1777 /run/mysqld ;\
    # ---- Config tweaks ------------------------------------------------- \
    # Snuff bind-address / log / user= in any shipped .cnf — they're either
    # wrong-for-container (bind 127.0.0.1) or duplicated by entrypoint.
    find /etc/mysql -name '*.cnf' -print0 \
      | xargs -0r grep -lZE '^(bind-address|log|user[[:space:]])' \
      | xargs -0rt sed -Ei 's/^(bind-address|log|user[[:space:]])/#&/' ;\
    # Container-specific override: don't reverse-resolve client IPs (they're
    # almost always sibling containers with no rDNS), and disable host-cache
    # so stale entries don't accumulate. Loads AFTER 60-myguard.cnf so it
    # overrides any conflicts there.
    # datadir=/var/lib/mysql is set by the package's 60-myguard.cnf now, so
    # we only need the container-specific bits here: don't reverse-resolve
    # client IPs (sibling containers, no rDNS) and disable the host cache.
    printf '[mariadb]\nhost-cache-size=0\nskip-name-resolve\n' \
      > /etc/mysql/mariadb.conf.d/70-container.cnf ;\
    # Fix dir-include ordering so 99-* drop-ins win (Issue #327 from
    # upstream's docker image).
    if [ -L /etc/mysql/my.cnf ]; then \
        sed -i -e '/includedir/ {N;s/\(.*\)\n\(.*\)/\n\2\n\1/}' /etc/mysql/mariadb.cnf ;\
    fi ;\
    # ---- Hardening sweep ---------------------------------------------- \
    # Drop any setuid/setgid bits the install pulled in. MariaDB doesn't
    # legitimately need any.
    find /usr -xdev \( -perm -4000 -o -perm -2000 \) -type f -exec chmod a-s {} \; 2>/dev/null || true

COPY --chmod=0755 docker-entrypoint.sh /usr/local/bin/
COPY --chmod=0755 healthcheck.sh       /usr/local/bin/

VOLUME /var/lib/mysql
EXPOSE 3306

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD healthcheck.sh --su-mysql --connect --innodb_initialized || exit 1

STOPSIGNAL SIGTERM

ENTRYPOINT ["docker-entrypoint.sh"]
CMD        ["mariadbd"]
