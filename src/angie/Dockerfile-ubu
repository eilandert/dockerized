# syntax=docker/dockerfile:1.7
FROM    docker.io/eilandert/ubuntu-base:rolling
# Supply-chain / provenance args, injected by docker-bake.hcl at build time.
ARG     VCS_REF=unknown
ARG     BUILD_DATE=unknown
LABEL   maintainer="Thijs Eilander <eilander@myguard.nl>" \
        org.opencontainers.image.title="Angie with ModSecurity & PageSpeed" \
        org.opencontainers.image.description="Hardened high-performance web server with security and optimization modules" \
        org.opencontainers.image.url="https://github.com/eilandert/dockerized" \
        org.opencontainers.image.source="https://github.com/eilandert/dockerized/tree/master/src/angie" \
        org.opencontainers.image.documentation="https://deb.myguard.nl/angie-dockerized/" \
        org.opencontainers.image.vendor="MyGuard" \
        org.opencontainers.image.licenses="BSD-2-Clause" \
        org.opencontainers.image.version="base" \
        org.opencontainers.image.revision="${VCS_REF}" \
        org.opencontainers.image.created="${BUILD_DATE}"
ENV     DEBIAN_FRONTEND="noninteractive"

COPY --chmod=0755 bootstrap.sh /bootstrap.sh
COPY --chmod=0755 healthcheck.sh /healthcheck.sh
COPY    healthz.conf /healthz.conf
COPY    default.conf-example /default.conf-example

# BuildKit cache mounts: apt lists+archives are kept on cache mounts (not in
# image layers), so we keep the docker-clean stub removal and skip the
# rm -rf /var/lib/apt/lists/* at the end — the mount handles it.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    set -ex ;\
    rm -f /etc/apt/apt.conf.d/docker-clean ;\
    echo "deb [signed-by=/usr/share/keyrings/deb.myguard.nl.gpg] http://deb.myguard.nl:8888 ${DIST} main" > /etc/apt/sources.list.d/deb.myguard.nl.list ;\
    apt-get update ;\
    apt-get -y -o Dpkg::Options::=--force-confnew -o Dpkg::Options::=--force-confmiss upgrade ;\
    apt-get -y --no-install-recommends install \
      brotli \
      curl \
      fcgiwrap \
      geoip-bin \
      libjemalloc2 \
      libluajit-5.1-2 \
      lua-http \
      lua-socket \
      lua-zlib \
      lua-resty \
      mimalloc \
      modsecurity-crs \
      angie-full \
      openssl \
      ssl-cert \
      zstd ;\
    mv /etc/angie /etc/angie.orig ;\
    mv /etc/modsecurity /etc/modsecurity.orig ;\
    mkdir -p /etc/angie /etc/modsecurity ;\
    install -m 0644 /healthz.conf /etc/angie.orig/sites-enabled/healthz ;\
    # Example default vhost: kept in sites-available, and enabled by default so \
    # the container serves HTTPS (snakeoil) out-of-the-box with no certs mounted. \
    mkdir -p /etc/angie.orig/sites-available ;\
    install -m 0644 /default.conf-example /etc/angie.orig/sites-available/default.conf-example ;\
    install -m 0644 /default.conf-example /etc/angie.orig/sites-enabled/default.conf ;\
    rm -f /healthz.conf /default.conf-example /var/spool/nullmailer/trigger ;\
    # The angie-full package already ships its own snippets/ (ssl-labs-aplus, \
    # security, cloudflare, proxy, …) into /etc/angie; we don't bundle our own. \
    # ---- HARDENING ---- \
    # Tighten perms on config dirs (master is root; workers drop to www-data) \
    chown -R root:www-data /etc/angie.orig /etc/modsecurity.orig ;\
    chmod -R go-w /etc/angie.orig /etc/modsecurity.orig ;\
    # Pre-create writable dirs with restrictive perms \
    install -d -m 0750 -o www-data -g www-data /var/cache/angie /var/log/angie ;\
    # Drop any setuid/setgid bits the install pulled in \
    find /usr -xdev \( -perm -4000 -o -perm -2000 \) -type f -exec chmod a-s {} \; 2>/dev/null || true

WORKDIR /etc/angie
EXPOSE  80
EXPOSE  443
EXPOSE  443/udp

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD /healthcheck.sh || exit 1

STOPSIGNAL SIGQUIT

CMD     ["/bootstrap.sh"]
