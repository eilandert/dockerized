# syntax=docker/dockerfile:1.7
# This file might be outdated, see https://github.com/eilandert/dockerized/tree/master/apache-phpfpm for a recent one

FROM    docker.io/eilandert/php-fpm:deb-8.0
LABEL   maintainer="Thijs Eilander <eilander@myguard.nl>" \
        org.opencontainers.image.title="Apache with PHP-FPM" \
        org.opencontainers.image.description="Apache web server with PHP-FPM FastCGI backend" \
        org.opencontainers.image.url="https://github.com/eilandert/dockerized" \
        org.opencontainers.image.source="https://github.com/eilandert/dockerized/tree/master/apache-phpfpm" \
        org.opencontainers.image.vendor="MyGuard" \
        org.opencontainers.image.version="8.0"
ENV     DEBIAN_FRONTEND="noninteractive" \
        TZ=Europe/Amsterdam
COPY --chmod=0755 bootstrap.sh /bootstrap.sh
COPY    conf-available /tmp/conf-available

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    set -ex ;\
    rm -f /etc/apt/apt.conf.d/docker-clean ;\
    apt-get -y update ;\
    apt-get install -y --no-install-recommends apache2 apache2-utils libjemalloc2 mimalloc ;\
    # autoindex   — silent directory listings when no DirectoryIndex matches \
    # negotiation — CVE-style file-extension fishing (foo.php.bak surfacing) \
    # Both are enabled by default on Debian/Ubuntu apache2; turn them off. \
    a2dismod status mpm_prefork autoindex negotiation ;\
    # http2: TLS multiplexing → fewer connections, less head-of-line blocking. \
    a2enmod mpm_event http2 proxy_fcgi setenvif rewrite expires headers remoteip ;\
    cp /tmp/conf-available/php${PHPVERSION}-fpm.conf /etc/apache2/conf-available ;\
    a2enconf php${PHPVERSION}-fpm ;\
    mv /etc/apache2 /etc/apache2.orig ;\
    mv /etc/nullmailer /etc/nullmailer.orig ;\
    mkdir -p /etc/apache2 /etc/php /etc/nullmailer ;\
    rm -rf /tmp/conf-available
EXPOSE  80
EXPOSE  443

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -fsS --max-time 3 -o /dev/null http://127.0.0.1/ || exit 1

CMD     ["/bootstrap.sh"]
